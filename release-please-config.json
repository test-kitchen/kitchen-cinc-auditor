{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    ".": {
      "release-type": "ruby",
      "package-name": "kitchen-cinc-auditor",
      "version-file": "lib/kitchen/verifier/cinc_auditor_version.rb",
      "changelog-path": "CHANGELOG.md",
      "include-v-in-tag": true,
      "changelog-sections": [
        {
          "type": "feat",
          "section": "Features"
        },
        {
          "type": "fix",
          "section": "Bug Fixes"
        },
        {
          "type": "perf",
          "section": "Performance"
        },
        {
          "type": "deps",
          "section": "Dependencies"
        },
        {
          "type": "docs",
          "section": "Documentation"
        },
        {
          "type": "chore",
          "section": "Maintenance",
          "hidden": true
        }
      ]
    }
  }
}
